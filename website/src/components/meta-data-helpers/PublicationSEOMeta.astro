---
interface Props {
  title: string
  description: string
  authors: string[]
  datePublished: Date
  dateModified?: Date
  landingUrl: string
  pdfUrl: string
  imageUrl: string
  pageCount: number
  version?: string
  searchKeywords: string[]
}

const {
  title,
  description,
  authors,
  datePublished,
  dateModified,
  landingUrl,
  pdfUrl,
  imageUrl,
  pageCount,
  version,
  searchKeywords,
} = Astro.props as Props

const publishedIso = datePublished.toISOString()
const modifiedIso = dateModified?.toISOString()
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: authors.map((name) => ({ '@type': 'Person', name })),
  datePublished: publishedIso,
  ...(modifiedIso ? { dateModified: modifiedIso } : {}),
  image: imageUrl,
  publisher: {
    '@type': 'Organization',
    name: 'Phaeno',
    url: new URL('/', landingUrl).href,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': landingUrl,
  },
  encoding: {
    '@type': 'MediaObject',
    name: `${title} PDF`,
    contentUrl: pdfUrl,
    encodingFormat: 'application/pdf',
  },
}
const serializedStructuredData = JSON.stringify(structuredData).replace(/</g, '\\u003c')
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="phaeno:document-type" content="White Paper" />
<meta name="phaeno:search-title" content={`White Paper - ${title}`} />
<meta name="phaeno:search-keywords" content={searchKeywords.join(', ')} />
<meta name="phaeno:search-mode" content="document" />
<meta name="phaeno:search-source" content={pdfUrl} />
<meta name="phaeno:search-source-type" content="application/pdf" />
<meta name="phaeno:publication-page-count" content={String(pageCount)} />
{version ? <meta name="phaeno:publication-version" content={version} /> : null}

<meta property="og:type" content="article" />
<meta property="og:site_name" content="Phaeno" />
<meta property="og:url" content={landingUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="article:published_time" content={publishedIso} />
{modifiedIso ? <meta property="article:modified_time" content={modifiedIso} /> : null}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@Phaeno" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<script type="application/ld+json" set:html={serializedStructuredData} />
