---
import { getCollection, render, type CollectionEntry } from 'astro:content'
import Layout from '@/layouts/Layout.astro'
import MediaArticlePage from '@/components/MediaArticlePage.astro'
import PublicationSEOMeta from '@/components/meta-data-helpers/PublicationSEOMeta.astro'
import { getWhitePaperPublication } from '@/lib/publications'

export async function getStaticPaths() {
  const papers = await getCollection('white_papers')
  return papers.map((paper) => ({
    params: { slug: paper.id },
    props: { paper },
  }))
}

const { paper } = Astro.props as { paper: CollectionEntry<'white_papers'> }
const {
  title,
  authors,
  date,
  dateModified,
  summary,
  image,
  pageCount,
  version,
  searchKeywords,
} = paper.data
const publication = getWhitePaperPublication(paper, Astro.site)
const { Content } = await render(paper)
---

<Layout>
  <PublicationSEOMeta
    slot="head"
    title={title}
    description={summary}
    authors={authors}
    datePublished={date}
    dateModified={dateModified}
    landingUrl={publication.landingUrl}
    pdfUrl={publication.pdfUrl}
    imageUrl={publication.imageUrl}
    pageCount={pageCount}
    version={version}
    searchKeywords={searchKeywords}
  />
  <MediaArticlePage
    title={title}
    summary={summary}
    image={image}
    authors={authors}
    date={date}
    eyebrow="Phaeno white paper"
    backHref="/media/white-papers"
    backLabel="Back to all white papers"
    headerActionHref={publication.pdfPath}
    headerActionLabel={`View ${pageCount}-page PDF`}
    pageCount={pageCount}
    version={version}
  >
    <Content />
  </MediaArticlePage>
</Layout>
