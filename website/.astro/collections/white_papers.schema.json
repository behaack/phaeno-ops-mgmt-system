{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "image": {
      "type": "string",
      "pattern": "^\\/images\\/.*"
    },
    "authors": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "dateModified": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "pageCount": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "topics": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "searchKeywords": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "image",
    "authors",
    "date",
    "summary",
    "pageCount",
    "topics",
    "searchKeywords"
  ]
}