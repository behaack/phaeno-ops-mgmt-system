{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "locationType": {
      "type": "string",
      "enum": [
        "Remote",
        "On-Site"
      ]
    },
    "locationDescription": {
      "type": "string"
    },
    "city": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "region": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "country": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "employmentType": {
      "type": "string",
      "enum": [
        "Full-time",
        "Part-time",
        "Contract",
        "Temporary",
        "Intern",
        "Other"
      ]
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "maxLength": 200
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "locationType",
    "locationDescription",
    "employmentType",
    "date",
    "summary"
  ]
}